<?xml version="1.0" standalone="yes"?>
<rss xmlns:sparkle="http://www.andymatuschak.org/xml-namespaces/sparkle" version="2.0">
  <channel>
    <title>Pomvox</title>
    <link>https://raw.githubusercontent.com/abhiram304/pomvox/main/appcast.xml</link>
    <description>Most recent updates to Pomvox</description>
    <language>en</language>
    <!--
      Release entries are generated by scripts/make-appcast.sh and committed here
      AFTER the matching GitHub release and its assets are published. Order
      matters: never publish an appcast entry whose enclosure URL 404s.

      A generated item looks like the following (sparkle:version is the
      CFBundleVersion; shortVersionString is the marketing version):

        item
          title 0.1.11
          sparkle:version 11
          sparkle:shortVersionString 0.1.11
          sparkle:minimumSystemVersion 14.0
          link .../releases/tag/v0.1.11
          enclosure url=.../releases/download/v0.1.11/Pomvox.zip
                    sparkle:edSignature=BASE64 length=BYTES
                    type=application/octet-stream

      An empty channel (no items) simply means "no update available", which is
      the correct state until the first updater-capable release ships.
    -->
  </channel>
</rss>
